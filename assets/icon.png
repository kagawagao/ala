<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <!-- Background circle -->
  <circle cx="100" cy="100" r="95" fill="#1e1e1e" stroke="#007acc" stroke-width="3"/>
  
  <!-- Android robot body -->
  <g transform="translate(100, 100)">
    <!-- Head -->
    <rect x="-20" y="-45" width="40" height="25" rx="3" fill="#4ec9b0"/>
    
    <!-- Antennas -->
    <line x1="-12" y1="-45" x2="-18" y2="-55" stroke="#4ec9b0" stroke-width="3" stroke-linecap="round"/>
    <line x1="12" y1="-45" x2="18" y2="-55" stroke="#4ec9b0" stroke-width="3" stroke-linecap="round"/>
    
    <!-- Eyes -->
    <circle cx="-10" cy="-35" r="2.5" fill="#1e1e1e"/>
    <circle cx="10" cy="-35" r="2.5" fill="#1e1e1e"/>
    
    <!-- Body -->
    <rect x="-20" y="-20" width="40" height="30" rx="3" fill="#4ec9b0"/>
    
    <!-- Arms -->
    <rect x="-30" y="-15" width="8" height="25" rx="4" fill="#4ec9b0"/>
    <rect x="22" y="-15" width="8" height="25" rx="4" fill="#4ec9b0"/>
    
    <!-- Legs -->
    <rect x="-15" y="10" width="8" height="20" rx="4" fill="#4ec9b0"/>
    <rect x="7" y="10" width="8" height="20" rx="4" fill="#4ec9b0"/>
    
    <!-- Log document overlay -->
    <g transform="translate(15, -10)">
      <!-- Document -->
      <rect x="0" y="0" width="30" height="35" rx="2" fill="#d4d4d4" opacity="0.95"/>
      <!-- Lines representing log entries -->
      <line x1="5" y1="8" x2="25" y2="8" stroke="#007acc" stroke-width="1.5"/>
      <line x1="5" y1="14" x2="25" y2="14" stroke="#f48771" stroke-width="1.5"/>
      <line x1="5" y1="20" x2="25" y2="20" stroke="#dcdcaa" stroke-width="1.5"/>
      <line x1="5" y1="26" x2="25" y2="26" stroke="#9cdcfe" stroke-width="1.5"/>
    </g>
  </g>
  
  <!-- ALA text at bottom -->
  <text x="100" y="180" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#4ec9b0" text-anchor="middle">ALA</text>
</svg>
