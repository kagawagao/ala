{
  "name": "ala",
  "version": "1.0.0",
  "description": "Android Log Analyzer - An Electron-based tool for analyzing Android logs with AI",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "tsc",
    "build:test": "tsc --project tsconfig.test.json",
    "build:icon": "node scripts/generate-icon.js",
    "build": "npm run build:icon && npm run build:ts && npm run build:renderer && electron-builder",
    "start": "npm run build:ts && npm run build:renderer && electron dist/main.js",
    "dev": "npm run build:ts && concurrently \"npm run serve\" \"npm run dev:electron\"",
    "dev:electron": "wait-on http://localhost:8080 && cross-env NODE_ENV=development electron dist/main.js --dev",
    "serve": "webpack serve --mode development",
    "watch:ts": "tsc --watch",
    "test": "npm run build:test && node dist/test/test-backend.js",
    "build:renderer": "webpack --mode production",
    "watch:renderer": "webpack --mode development --watch",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "postinstall": "node scripts/generate-icon.js || echo 'Icon generation skipped (using pre-generated icons)'"
  },
  "keywords": [
    "android",
    "log",
    "analyzer",
    "electron",
    "ai"
  ],
  "author": "Jingsong Gao",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-webpack-plugin": "^5.6.5",
    "prettier": "^3.2.5",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "worker-loader": "^3.0.8"
  },
  "dependencies": {
    "@ant-design/x": "^2.1.3",
    "antd": "^6.2.0",
    "dayjs": "^1.11.10",
    "i18next": "^25.7.4",
    "openai": "^4.20.0",
    "rc-virtual-list": "^3.19.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.3"
  },
  "build": {
    "appId": "com.kagawagao.ala",
    "productName": "Android Log Analyzer",
    "directories": {
      "output": "dist/build"
    },
    "files": [
      "dist/**/*",
      "assets/icons/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icons/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/512x512.png"
    }
  }
}
