{
  "name": "ala",
  "version": "1.0.0",
  "description": "Android Log Analyzer - An Electron-based tool for analyzing Android logs with AI",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "tsc",
    "build:css": "npx tailwindcss -i ./src/renderer/input.css -o ./src/renderer/styles.css --minify",
    "build": "npm run build:ts && npm run build:css && electron-builder",
    "start": "npm run build:ts && npm run build:css && electron dist/main.js",
    "dev": "npm run build:ts && npm run build:css && electron dist/main.js --dev",
    "watch:css": "npx tailwindcss -i ./src/renderer/input.css -o ./src/renderer/styles.css --watch",
    "watch:ts": "tsc --watch",
    "test": "npm run build:ts && node dist/test/test-backend.js"
  },
  "keywords": [
    "android",
    "log",
    "analyzer",
    "electron",
    "ai"
  ],
  "author": "Jingsong Gao",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.8",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "openai": "^4.20.0"
  },
  "build": {
    "appId": "com.kagawagao.ala",
    "productName": "Android Log Analyzer",
    "directories": {
      "output": "dist/build"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
