{
  "name": "ala",
  "version": "1.0.0",
  "description": "Android Log Analyzer - An Electron-based tool for analyzing Android logs with AI",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "tsc",
    "build:test": "tsc --project tsconfig.test.json",
    "build:css": "npx tailwindcss -i ./src/renderer/input.css -o ./src/renderer/styles.css --minify",
    "build:icon": "node scripts/generate-icon.js",
    "build": "npm run build:icon && npm run build:ts && npm run build:renderer && electron-builder",
    "start": "npm run build:ts && npm run build:renderer && electron dist/main.js",
    "dev": "npm run build:ts && npm run build:renderer && electron dist/main.js --dev",
    "watch:css": "npx tailwindcss -i ./src/renderer/input.css -o ./src/renderer/styles.css --watch",
    "watch:ts": "tsc --watch",
    "test": "npm run build:test && node dist/test/test-backend.js",
    "build:renderer": "webpack --mode production",
    "watch:renderer": "webpack --mode development --watch",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "postinstall": "npm run build:icon"
  },
  "keywords": [
    "android",
    "log",
    "analyzer",
    "electron",
    "ai"
  ],
  "author": "Jingsong Gao",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.23",
    "css-loader": "^7.1.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-webpack-plugin": "^5.6.5",
    "postcss-loader": "^8.2.0",
    "prettier": "^3.2.5",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.19",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "openai": "^4.20.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "build": {
    "appId": "com.kagawagao.ala",
    "productName": "Android Log Analyzer",
    "directories": {
      "output": "dist/build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}